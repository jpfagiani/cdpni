$TTL 7200 ; default para registros sem TTL
;
@	IN	SOA	ns1.cdpni.sap.	analista.cdpni.sap. (
	2023102518 ; serial
	8h ; refresh
	1h ; retry
	3d ; expire
	3h ; negative caching TTL
);
;
@			IN	NS		ns1.cdpni.sap.
@			IN	MX		10 mail.cdpni.sap.
@			IN	A		10.14.29.12
ns1			IN	A		10.14.29.10
www			IN	A		10.14.29.11
ftp			IN	CNAME		www
mail			IN	A		10.14.29.10
smtp			IN	CNAME		mail
pop				IN	CNAME		mail
imap			IN	CNAME		mail
webmail			IN	CNAME		mail
gateway			IN	A		10.14.29.1
intranet		IN	A		10.14.29.10
storage			IN	A		10.14.29.11
interno			IN	A		10.14.29.15
ad				IN	A		10.14.29.12
express			IN	A		10.14.29.10
ldap			IN  A       10.14.29.10
