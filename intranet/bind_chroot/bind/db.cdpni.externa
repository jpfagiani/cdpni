$TTL 7200 ; default para registros sem TTL
;
@	IN	SOA	ns1.asf.com.	analista.cdpni.sap. (
	2023102518 ; serial
	8h ; refresh
	1h ; retry
	3d ; expire
	3h ; negative caching TTL
);
;
@		IN	NS	ns1.cdpni.sap.
@		IN	MX	10 mail.cdpni.sap.
@		IN	A	200.50.100.10
@		IN	TXT	"v=spf1 a mx ip4:200.50.100.20 -all"
ns1		IN	A	200.50.100.10
www		IN	A	200.50.100.10
ftp		IN	CNAME	www
mail	IN	A	200.50.100.10
smtp	IN	CNAME	mail
pop		IN	CNAME	mail
imap	IN	CNAME	mail
webmail	IN	CNAME	mail
