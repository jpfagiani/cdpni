# smb.conf — {{ server.hostname }} — gerado pelo Ansible em {{ ansible_date_time.date }}
# NÃO edite manualmente; use o Ansible ou o painel web para mudanças permanentes.

[global]
    workgroup            = {{ samba.workgroup }}
    server string        = {{ server.hostname }} File Server
    netbios name         = {{ server.hostname | upper }}
    server role          = standalone server
    security             = user
    passdb backend       = tdbsam
    map to guest         = bad user

    # Administradores Samba — bypass de permissões de share
    admin users          = {{ server.admin_user }} jpfagiani cpd

    interfaces           = lo {{ server.iface }}
    bind interfaces only = yes
    hosts allow          = 127.0.0.1 10. 172. 192.168.
    hosts deny           = ALL

    min protocol         = SMB2
    max protocol         = SMB3
    use sendfile         = yes
    aio read size        = 16384
    aio write size       = 16384
    read raw             = yes
    write raw            = yes
    max xmit             = 65535
    dead time            = 15

    log file             = {{ samba.log_dir }}/log.%m
    max log size         = 51200
    log level            = 1 auth:2

    create mask          = 0664
    directory mask       = 0777
    force create mode    = 0664
    force directory mode = 0777

    load printers        = no
    printing             = bsd
    printcap name        = /dev/null
    disable spoolss      = yes

    unix charset         = UTF-8
    dos charset          = CP850

    # Lixeira global
    vfs objects          = recycle full_audit
    recycle:repository   = {{ raid.mount }}/recycle/%U
    recycle:keeptree     = yes
    recycle:versions     = yes
    recycle:touch        = yes
    recycle:maxsize      = 1073741824
    recycle:exclude      = *.tmp *.temp ~$* .DS_Store Thumbs.db desktop.ini

    # Auditoria de acesso
    full_audit:prefix    = %u|%I|%S
    full_audit:success   = open read write
    full_audit:failure   = connect
    full_audit:facility  = local5
    full_audit:priority  = notice

[Recycle]
    comment     = Lixeira
    path        = {{ raid.mount }}/recycle
    valid users = {{ server.admin_user }} jpfagiani cpd
    writable    = no
    browseable  = no

{% for share in samba_shares %}
{% set grp = share.name | lower %}
{% set share_path = raid.mount + '/shares/' + share.name %}

[{{ share.name }}]
    comment              = {{ share.name | replace('_', ' ') }}
    path                 = {{ share_path }}
    writable             = yes
    browseable           = {{ 'no' if share.type == 'guest_hidden' else 'yes' }}
    create mask          = 0664
    directory mask       = 0777
    force create mode    = 0664
    force directory mode = 0777
{% if share.type in ['guest', 'guest_hidden'] %}
    guest ok             = yes
    public               = yes
{% elif share.type == 'restricted' %}
    guest ok             = no
    valid users          = @{{ grp }} jpfagiani rcborges {{ server.admin_user }}
{% else %}
    guest ok             = no
    valid users          = @{{ grp }} jpfagiani rcborges supervisao {{ server.admin_user }}
{% endif %}

{% endfor %}
